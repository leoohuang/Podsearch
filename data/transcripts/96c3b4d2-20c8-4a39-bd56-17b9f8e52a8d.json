{
  "audio_path": "/Users/leohuang/podsearch/data/raw_audio/硅谷101/96c3b4d2-20c8-4a39-bd56-17b9f8e52a8d.mp3",
  "language": "zh",
  "duration": 133.845375,
  "segments": [
    {
      "start": 0.08,
      "end": 5.88,
      "text": "大家好 歡迎收聽歸鼓腰靈腰我是紅軍"
    },
    {
      "start": 5.88,
      "end": 9.08,
      "text": "這集是一個現象見面會的小預告"
    },
    {
      "start": 9.08,
      "end": 12.08,
      "text": "我們歸鼓腰靈腰團隊會在10月19號"
    },
    {
      "start": 12.08,
      "end": 18.08,
      "text": "在南灣的桑尼苗 Plagam Play 直班一場五百到七百人左右的AI大會"
    },
    {
      "start": 18.08,
      "end": 23.08,
      "text": "那時間也就是10月的第三個週六的下午"
    },
    {
      "start": 23.08,
      "end": 28.08,
      "text": "這也是我們團隊第一次跟大家做這種非常大型的現象見面會"
    },
    {
      "start": 28.08,
      "end": 34.08,
      "text": "我們邀請活動嘉賓的標準跟我們平時路坡課也是一樣的希望有干貨有料"
    },
    {
      "start": 34.08,
      "end": 40.08,
      "text": "比如說我們邀請到了Peter Tiao的Founders Founder 基金的核火人上流"
    },
    {
      "start": 40.08,
      "end": 45.08,
      "text": "以及過去很多出現在我們播課的人器嘉賓想張路豪小的一甲心"
    },
    {
      "start": 45.08,
      "end": 47.08,
      "text": "還有大家喜歡的人器主持人"
    },
    {
      "start": 47.08,
      "end": 51.08,
      "text": "呈現有兵艷都會來到我們的現場 那我也會去"
    },
    {
      "start": 51.08,
      "end": 57.08,
      "text": "除了這些老面孔 我們的現象活動還會有很多前年科技的新面孔跟大家一起"
    },
    {
      "start": 57.08,
      "end": 61.08,
      "text": "去討論各種階地氣的AI應用"
    },
    {
      "start": 61.08,
      "end": 66.08,
      "text": "比如說AI怎麼去跟教育演消費甚至是場受抗帥相結合"
    },
    {
      "start": 66.08,
      "end": 70.08,
      "text": "還有最近市場對這輪大模形弱潮是不是到了一個軌點"
    },
    {
      "start": 70.08,
      "end": 72.08,
      "text": "也存在著非常多的爭議"
    },
    {
      "start": 72.08,
      "end": 77.08,
      "text": "歡迎大家來現場聽一聽一起市場還有二集市場的投資人怎麼說"
    },
    {
      "start": 77.08,
      "end": 82.08,
      "text": "以及他們如何看待現在這些AI公司的股價的"
    },
    {
      "start": 82.08,
      "end": 85.08,
      "text": "感興趣的同學歡迎感情報名"
    },
    {
      "start": 85.08,
      "end": 88.08,
      "text": "活動的報名念階我會放在播課的修弄當中"
    },
    {
      "start": 88.08,
      "end": 91.08,
      "text": "這個鏈接場期有效一直會到10月19號"
    },
    {
      "start": 91.08,
      "end": 95.08,
      "text": "但是我們的活動早鳥加9月20號就結智了"
    },
    {
      "start": 95.08,
      "end": 97.08,
      "text": "就是還有兩天的時間"
    },
    {
      "start": 97.08,
      "end": 102.08,
      "text": "我們也會抽取三名幸運聽眾免費症送我們的門票"
    },
    {
      "start": 102.08,
      "end": 105.08,
      "text": "歡迎大家在評論區下方給我們留言"
    },
    {
      "start": 105.08,
      "end": 108.08,
      "text": "或者發有見到Podcast"
    },
    {
      "start": 108.08,
      "end": 110.08,
      "text": "sv要領邀點NEP"
    },
    {
      "start": 110.08,
      "end": 117.08,
      "text": "我在說一遍有相的地址p-o-d-c-a-s-t-at-sv要領邀點NEP"
    },
    {
      "start": 117.08,
      "end": 119.08,
      "text": "那期待跟大家現象見"
    },
    {
      "start": 119.08,
      "end": 122.08,
      "text": "另外說到這裡我知道很多小伙伴要推功來"
    },
    {
      "start": 122.08,
      "end": 125.08,
      "text": "我們最近的就是節目也正在加緊製作中"
    },
    {
      "start": 125.08,
      "end": 127.08,
      "text": "最近兩天也會發布"
    },
    {
      "start": 127.08,
      "end": 129.08,
      "text": "請大家持續的關注我們"
    }
  ]
}